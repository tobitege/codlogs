{
  "name": "codlogs",
  "version": "1.3.2",
  "private": true,
  "description": "Codex session CLI and Electrobun browser.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "codlogs": "./codlogs.cjs",
    "codlogs-sessions": "./codlogs-sessions.cjs"
  },
  "scripts": {
    "build:web": "vite build",
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build"
  },
  "files": [
    "README.md",
    "codlogs.cjs",
    "codlogs-sessions.cjs",
    "codlogs-sessions.ts",
    "electrobun.config.ts",
    "vite.config.ts",
    "tsconfig.json",
    "src"
  ],
  "engines": {
    "node": ">=22.11.0",
    "bun": ">=1.3.12"
  },
  "dependencies": {
    "electrobun": "1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "typescript": "^6.0.3",
    "vite": "8.0.16"
  }
}
