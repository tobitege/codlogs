{
  "name": "codlogs",
  "version": "1.1.0",
  "private": true,
  "description": "Codex session CLI and Electrobun browser.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "bin": {
    "codlogs": "./codlogs.cjs",
    "codlogs-sessions": "./codlogs-sessions.cjs"
  },
  "scripts": {
    "build:web": "vite build",
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build"
  },
  "files": [
    "README.md",
    "codlogs.cjs",
    "codlogs-sessions.cjs",
    "codlogs-sessions.ts",
    "electrobun.config.ts",
    "vite.config.ts",
    "tsconfig.json",
    "src"
  ],
  "engines": {
    "node": ">=22.11.0",
    "bun": ">=1.3.9"
  },
  "dependencies": {
    "electrobun": "1.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
